# Supabase - Required
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot - Required for production security
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# Admin Panel Password - Set before first deploy
# This is the default password to log into /admin
# After first login you can change it from the admin panel
ADMIN_PASSWORD=change-me-before-deploy

# Session Secret - Required (used for admin session signing)
# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=your-random-secret-min-32-chars

# Blockchain Explorer APIs - Optional (for deposit verification)
# Get free keys from etherscan.io, bscscan.com, polygonscan.com
ETHERSCAN_API_KEY=your-etherscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key
